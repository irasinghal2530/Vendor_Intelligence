# Ollama — LLM for analysis and chat (no Gemini/API key required)
OLLAMA_MODEL=qwen3-vl:235b-instruct-cloud
# Backend on your machine + Ollama on your machine:
OLLAMA_BASE_URL=http://localhost:11434
# Backend in Docker + Ollama on host (Docker Desktop): use http://host.docker.internal:11434

# Frontend → backend (local Streamlit)
BACKEND_URL=http://127.0.0.1:8000
